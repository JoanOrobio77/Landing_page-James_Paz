            "content": "<!DOCTYPE html>\r\n<html lang=\"es\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Yo Soy James | Transformación Espiritual y Conciencia</title>\r\n    <link rel=\"stylesheet\" href=\"styles.css\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Outfit:wght@300;400;500&display=swap\" rel=\"stylesheet\">\r\n</head>\r\n<body>\r\n    <!-- Section 1 — Hero -->\r\n    <section class=\"hero\" id=\"hero\">\r\n        <div class=\"hero-bg\" style=\"background-image: url('images/Imagen_james2.jpg');\"></div>\r\n        <div class=\"hero-overlay\"></div>\r\n        <div class=\"hero-content\">\r\n            <h1 class=\"hero-logo\">Yo Soy James</h1>\r\n            <p class=\"hero-subtitle\">Transformación espiritual y conciencia.</p>\r\n            <a href=\"#servicios\" class=\"btn btn-glow\">Iniciar mi transformación</a>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Section 2 — Mensaje Espiritual -->\r\n    <section class=\"mensaje section-fade\" id=\"mensaje\">\r\n        <div class=\"container\">\r\n            <h2 class=\"section-title\">El verdadero cambio comienza dentro de ti</h2>\r\n            <div class=\"mensaje-content\">\r\n                <p>Transformación real comienza con compromiso real.</p>\r\n                <p>Todo entrenamiento espiritual es una puerta,<br>pero solo tú decides cruzarla.</p>\r\n                <p>Aquí no encontrarás promesas vacías<br>ni certificados que cuelgan en una pared.</p>\r\n                <p>El verdadero reconocimiento<br>es la transformación de tu vida.</p>\r\n                <p>Si decides caminar este camino,<br>hazlo con un compromiso del 101%.</p>\r\n                <p>Porque tus resultados<br>serán tu verdadera certificación.</p>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Section 3 — Filosofía -->\r\n    <section class=\"filosofia section-fade\" id=\"filosofia\">\r\n        <div class=\"container\">\r\n            <h2 class=\"section-title\">Una espiritualidad vivida</h2>\r\n            <div class=\"filosofia-content\">\r\n                <p>La espiritualidad no es teoría.</p>\r\n                <p>Es experiencia.</p>\r\n                <p>No se trata de acumular conocimiento,<br>sino de transformar tu conciencia,<br>tu energía<br>y tu forma de vivir.</p>\r\n                <p>Cada sesión, cada curso y cada guía<br>está diseñado para acompañarte<br>en un proceso real de cambio interior.</p>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Section 4 — Servicios -->\r\n    <section class=\"servicios section-fade\" id=\"servicios\">\r\n        <div class=\"container\">\r\n            <h2 class=\"section-title\">Servicios</h2>\r\n            <div class=\"servicios-grid\">\r\n                <div class=\"service-card\">\r\n                    <h3>Sesión Individual</h3>\r\n                    <p class=\"service-desc\">Espacio profundo de claridad y transformación personal</p>\r\n                    <p class=\"price\">$55 USD</p>\r\n                    <a href=\"#pagos\" class=\"btn btn-card\">Reservar</a>\r\n                </div>\r\n                <div class=\"service-card\">\r\n                    <h3>Guía Mensual Privada</h3>\r\n                    <p class=\"service-desc\">Acompañamiento continuo en tu proceso espiritual</p>\r\n                    <p class=\"price\">$300 USD</p>\r\n                    <a href=\"#pagos\" class=\"btn btn-card\">Reservar</a>\r\n                </div>\r\n                <div class=\"service-card\">\r\n                    <h3>Curso del Amor</h3>\r\n                    <p class=\"service-desc\">Sanación emocional y apertura del corazón</p>\r\n                    <p class=\"price\">$350 USD</p>\r\n                    <a href=\"#pagos\" class=\"btn btn-card\">Reservar</a>\r\n                </div>\r\n                <div class=\"service-card\">\r\n                    <h3>Curso del Propósito</h3>\r\n                    <p class=\"service-desc\">Descubre tu misión de vida y dirección espiritual</p>\r\n                    <p class=\"price\">$400 USD</p>\r\n                    <a href=\"#pagos\" class=\"btn btn-card\">Reservar</a>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Section 5 — Pagos -->\r\n    <section class=\"pagos section-fade\" id=\"pagos\">\r\n        <div class=\"container\">\r\n            <h2 class=\"section-title\">Inversión en tu transformación</h2>\r\n            <div class=\"pagos-content\">\r\n                <p>Pagos disponibles vía PayPal</p>\r\n                <p class=\"pagos-email\">jamesjair24@gmail.com</p>\r\n                <a href=\"https://www.paypal.com/paypalme/jamesjair24\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"btn btn-paypal\">\r\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M7.076 21.337H2.47a.5.5 0 0 1-.495-.57L4.944.901C5.021.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.044.9l-1.12 7.106z\"/></svg>\r\n                    Pagar con PayPal\r\n                </a>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Section 6 — Perfil -->\r\n    <section class=\"perfil section-fade\" id=\"perfil\">\r\n        <div class=\"container\">\r\n            <div class=\"perfil-content\">\r\n                <div class=\"perfil-image-wrapper\">\r\n                    <img src=\"images/Imagen_james2.jpg\" alt=\"James - Guía de transformación espiritual\" class=\"perfil-image\">\r\n                </div>\r\n                <h2 class=\"perfil-name\">James</h2>\r\n                <p class=\"perfil-desc\">Guía de transformación espiritual<br>y acompañamiento consciente.</p>\r\n            </div>\r\n        </div>\r\n    </section>\r\n\r\n    <!-- Section 7 — Redes Sociales -->\r\n    <section class=\"redes section-fade\" id=\"redes\">\r\n        <div class=\"container\">\r\n            <h2 class=\"section-title\">Conecta conmigo</h2>\r\n            <p class=\"redes-text\">Síguenos y forma parte de esta comunidad de transformación.</p>\r\n            <div class=\"redes-grid\">\r\n                <a href=\"https://www.youtube.com/@yosoyjames3\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-btn\" aria-label=\"YouTube\">\r\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z\"/></svg>\r\n                    <span>YouTube</span>\r\n                </a>\r\n                <a href=\"https://www.tiktok.com/@yosoyjames3?_r=1&_t=ZS-94gmtdFTMFb\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-btn\" aria-label=\"TikTok\">\r\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z\"/></svg>\r\n                    <span>TikTok</span>\r\n                </a>\r\n               